# Copie este arquivo para .env e preencha os valores
# DATABASE_URL vem do painel do Supabase: Project Settings > Database > Connection String (URI)
# Use a "Connection pooling" string (porta 6543), não a direct connection (porta 5432)

DATABASE_URL=postgresql://postgres.xxxxxxxxxxxx:SUA_SENHA@aws-0-sa-east-1.pooler.supabase.com:6543/postgres
NODE_ENV=development
PORT=3001

# URL do frontend (necessário em produção para o CORS)
FRONTEND_URL=https://adsi-frontend.onrender.com
